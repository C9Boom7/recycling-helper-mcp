{
  "name": "recycling-helper-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc && mkdir -p dist/data && cp src/data/*.json dist/data/",
    "start": "node dist/server.js",
    "validate:data": "node scripts/validate-data.mjs",
    "eval:data": "node scripts/evaluate-data.mjs",
    "check": "tsc --noEmit && node scripts/validate-data.mjs && node scripts/evaluate-data.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "express": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
